# Admissions Officer — Environment Variables
# Copy this file to .env and fill in your values.

# Required: Your Google Gemini API key
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Gemini model to use for all AI tasks
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: Port for local server (default: 3000)
# PORT=3000

# Set automatically by AO on first run — do not edit manually:
# DATA_DIR=/Users/yourname/ao-profile
