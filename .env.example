# Admissions Officer — environment configuration
# Copy this file to .env and fill in your values.
# On first run without a .env, the UI will prompt you to enter these via the setup modal.

# Required: Your Google Gemini API key (get one free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Required: Gemini model name to use for all AI tasks
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: Port for the local server (default: 3000)
PORT=3000

# Optional: Directory where student profile data is stored (set on first run)
DATA_DIR=
